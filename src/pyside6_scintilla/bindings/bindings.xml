<?xml version="1.0" encoding="UTF-8"?>
<!--
     shiboken6 typesystem for the `_pyside6_scintilla` extension module.

     Declares which of the C++ types visible through bindings.h get Python
     wrappers generated. shiboken errors out (naming the missing type) if a
     wrapped member references something not declared here; see
     docs/bindings.md for that iterative process.

     The <enum-type> list below covers every `enum class` in
     ScintillaTypes.h (plus Message from ScintillaMessages.h), not just the
     ones referenced by ScintillaEditBase/ScintillaEdit's bound C++
     signatures (which are almost all plain `sptr_t`/int, generated from
     Scintilla.iface). Exposing the full set under the Scintilla namespace
     gives Python callers a typed constant for every SCI_* message
     parameter/return value, instead of having to hardcode the matching
     SC_*/SCI_* magic int themselves (see issue #1). -->
<typesystem package="_pyside6_scintilla">
    <load-typesystem name="typesystem_widgets.xml" generate="no"/>

    <!-- ScintillaEditBase::send/sends use the global ::sptr_t (Scintilla.h's
         "typedef intptr_t sptr_t"), not Scintilla::sptr_t. shiboken
         auto-registers single-step typedefs to known primitives (e.g.
         uintptr_t -> unsigned long), but on macOS intptr_t is a two-step
         typedef (intptr_t -> __darwin_intptr_t -> long), which it doesn't
         auto-resolve - leaving ::sptr_t unrecognized and silently dropping
         send/sends entirely. Register it explicitly so this matches the
         Linux/Windows behavior. -->
    <primitive-type name="sptr_t"/>

    <namespace-type name="Scintilla">
        <!-- Integer typedefs used throughout ScintillaEditBase's public API -->
        <primitive-type name="Position"/>
        <primitive-type name="sptr_t"/>
        <primitive-type name="uptr_t"/>

        <enum-type name="Accessibility"/>
        <enum-type name="Alpha"/>
        <enum-type name="AnnotationVisible"/>
        <enum-type name="AutoCompleteOption"/>
        <enum-type name="AutomaticFold"/>
        <enum-type name="Bidirectional"/>
        <enum-type name="CaretPolicy"/>
        <enum-type name="CaretSticky"/>
        <enum-type name="CaretStyle"/>
        <enum-type name="CaseInsensitiveBehaviour"/>
        <enum-type name="CaseVisible"/>
        <enum-type name="ChangeHistoryOption"/>
        <enum-type name="CharacterSet"/>
        <enum-type name="CharacterSource"/>
        <enum-type name="CompletionMethods"/>
        <enum-type name="CursorShape"/>
        <enum-type name="DocumentOption"/>
        <enum-type name="EOLAnnotationVisible"/>
        <enum-type name="EdgeVisualStyle"/>
        <enum-type name="Element"/>
        <enum-type name="EndOfLine"/>
        <enum-type name="FindOption"/>
        <enum-type name="FocusChange"/>
        <enum-type name="FoldAction"/>
        <enum-type name="FoldDisplayTextStyle"/>
        <enum-type name="FoldFlag"/>
        <enum-type name="FoldLevel"/>
        <enum-type name="FontQuality"/>
        <enum-type name="FontStretch"/>
        <enum-type name="FontWeight"/>
        <enum-type name="IMEInteraction"/>
        <enum-type name="IdleStyling"/>
        <enum-type name="IndentView"/>
        <enum-type name="IndicFlag"/>
        <enum-type name="IndicValue"/>
        <enum-type name="IndicatorNumbers"/>
        <enum-type name="IndicatorStyle"/>
        <enum-type name="Keys"/>
        <enum-type name="KeyMod"/>
        <enum-type name="Layer"/>
        <enum-type name="LineCache"/>
        <enum-type name="LineCharacterIndexType"/>
        <enum-type name="LineEndType"/>
        <enum-type name="MarginOption"/>
        <enum-type name="MarginType"/>
        <enum-type name="MarkerOutline"/>
        <enum-type name="MarkerSymbol"/>
        <enum-type name="Message"/>
        <enum-type name="ModificationFlags"/>
        <enum-type name="MultiAutoComplete"/>
        <enum-type name="MultiPaste"/>
        <enum-type name="Notification"/>
        <enum-type name="Ordering"/>
        <enum-type name="PhasesDraw"/>
        <enum-type name="PopUp"/>
        <enum-type name="PrintOption"/>
        <enum-type name="RepresentationAppearance"/>
        <enum-type name="SelectionMode"/>
        <enum-type name="Status"/>
        <enum-type name="StylesCommon"/>
        <enum-type name="Supports"/>
        <enum-type name="TabDrawMode"/>
        <enum-type name="Technology"/>
        <enum-type name="TypeProperty"/>
        <enum-type name="Update"/>
        <enum-type name="UndoFlags"/>
        <enum-type name="UndoSelectionHistoryOption"/>
        <enum-type name="VirtualSpace"/>
        <enum-type name="VisiblePolicy"/>
        <enum-type name="WhiteSpace"/>
        <enum-type name="Wrap"/>
        <enum-type name="WrapIndentMode"/>
        <enum-type name="WrapVisualFlag"/>
        <enum-type name="WrapVisualLocation"/>

        <value-type name="NotificationData">
            <!-- Scintilla::Message is registered twice when this field is
                 visible (ScintillaStructures.h forward-declares "enum class
                 Message;" before NotificationData, in addition to the full
                 definition in ScintillaMessages.h), causing shiboken to emit
                 duplicate enum converters/type indices for Scintilla::Message. -->
            <modify-field name="message" remove="true"/>
        </value-type>
    </namespace-type>

    <!-- Several of ScintillaEditBase's signals carry
         Scintilla::Position/ModificationFlags/FoldLevel/etc. parameters
         that Qt's generic meta-call path can't convert when invoking a
         Python slot (the connection silently fails, see
         scintilla_signal_fixes.h). ScintillaEditBaseFixed below redeclares
         each affected signal with a plain-int signature; since Qt signals
         are exposed to Python via PySide's own metaobject introspection
         (not via this typesystem's <modify-function>, which only affects
         ordinary methods), the subclass's redeclaration simply shadows the
         inherited broken one through normal Python attribute/MRO lookup,
         so nothing needs to be (or can usefully be) removed here.

         Still bound here (not generate="no") despite ScintillaEditBaseFixed
         being the only Python-visible class (see __init__.py): shiboken
         derives each generated file's required #include order from which
         bound types use it, and ScintillaEditBase.h is what keeps
         ScintillaTypes.h (Position et al.) included before
         ScintillaStructures.h (NotificationData et al., which needs
         Position) in the generated module header. Losing that via
         generate="no" left Position undefined when compiling
         ScintillaStructures.h. -->
    <object-type name="ScintillaEditBase"/>

    <!-- Python-visible as ScintillaEditBase (see __init__.py); see the
         ScintillaEditBase entry above for why this exists. -->
    <object-type name="ScintillaEditBaseFixed"/>

    <!-- shiboken handles the ScintillaDocument(QObject *parent = 0,
         void *pdoc_ = 0) constructor's void* fine as-is (surfaced as
         shiboken6.Shiboken.VoidPtr), so ScintillaDocument() can be
         constructed standalone in Python - e.g. to create a document up
         front and attach it to multiple ScintillaEdit widgets via
         set_doc() before any of them have text. -->
    <object-type name="ScintillaDocument"/>

    <!-- Not Python-visible directly (see __init__.py), for the same reason
         as ScintillaEditBase above: it inherits the same broken-signature
         signals directly from the vendored ScintillaEditBase, not from
         ScintillaEditBaseFixed. ScintillaEditFixed below redeclares them. -->
    <object-type name="ScintillaEdit">
        <!-- get_doc() returns a fresh heap ScintillaDocument with no Qt parent;
             give Python ownership so it's freed when the wrapper is garbage
             collected. Declared here rather than on ScintillaEditFixed below
             (the class actually exposed to Python, see __init__.py): the
             typesystem only honors modify-function for the class that
             declares the method, not a subclass that merely inherits it,
             so putting it on ScintillaEditFixed silently no-ops.
             ScintillaEditFixed inherits this ownership rule from here. -->
        <modify-function signature="get_doc()">
            <modify-argument index="return">
                <define-ownership owner="target"/>
            </modify-argument>
        </modify-function>
    </object-type>

    <!-- Python-visible as ScintillaEdit (see __init__.py). -->
    <object-type name="ScintillaEditFixed"/>
</typesystem>
