<?xml version="1.0" encoding="UTF-8"?>
<!--
     shiboken6 typesystem for the `_pyside6_scintilla` extension module.

     Declares which of the C++ types visible through bindings.h get Python
     wrappers generated. Only types actually referenced by ScintillaEditBase's
     public signals/slots/methods need to be listed; shiboken errors out
     (naming the missing type) if a wrapped member references something not
     declared here. See docs/bindings.md for the iterative process of growing
     this file (e.g. for Phase 2's ScintillaEdit).
-->
<typesystem package="_pyside6_scintilla">
    <load-typesystem name="typesystem_widgets.xml" generate="no"/>

    <!-- ScintillaEditBase::send/sends use the global ::sptr_t (Scintilla.h's
         "typedef intptr_t sptr_t"), not Scintilla::sptr_t. shiboken
         auto-registers single-step typedefs to known primitives (e.g.
         uintptr_t -> unsigned long), but on macOS intptr_t is a two-step
         typedef (intptr_t -> __darwin_intptr_t -> long), which it doesn't
         auto-resolve - leaving ::sptr_t unrecognized and silently dropping
         send/sends entirely. Register it explicitly so this matches the
         Linux/Windows behavior. -->
    <primitive-type name="sptr_t"/>

    <namespace-type name="Scintilla">
        <!-- Integer typedefs used throughout ScintillaEditBase's public API -->
        <primitive-type name="Position"/>
        <primitive-type name="sptr_t"/>
        <primitive-type name="uptr_t"/>

        <enum-type name="Update"/>
        <enum-type name="ModificationFlags"/>
        <enum-type name="FoldLevel"/>
        <enum-type name="KeyMod"/>
        <enum-type name="Notification"/>
        <enum-type name="CompletionMethods"/>
        <enum-type name="CharacterSource"/>
        <enum-type name="Message"/>
        <enum-type name="MarginType"/>
        <enum-type name="StylesCommon"/>
        <enum-type name="VirtualSpace"/>

        <value-type name="NotificationData">
            <!-- Scintilla::Message is registered twice when this field is
                 visible (ScintillaStructures.h forward-declares "enum class
                 Message;" before NotificationData, in addition to the full
                 definition in ScintillaMessages.h), causing shiboken to emit
                 duplicate enum converters/type indices for Scintilla::Message. -->
            <modify-field name="message" remove="true"/>
        </value-type>
    </namespace-type>

    <object-type name="ScintillaEditBase"/>

    <!-- ScintillaDocument (returned/taken by get_doc/set_doc) isn't wrapped -
         excluding it here is simpler than introducing a second wrapped type
         for a document-sharing feature nothing in this binding uses yet. -->
    <object-type name="ScintillaEdit">
        <modify-function signature="get_doc()" remove="all"/>
        <modify-function signature="set_doc(ScintillaDocument*)" remove="all"/>
    </object-type>
</typesystem>
